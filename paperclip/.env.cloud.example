HOST=0.0.0.0
PORT=3100
SERVE_UI=true

PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public
BETTER_AUTH_BASE_URL=https://your-domain.example
PAPERCLIP_PUBLIC_URL=https://your-domain.example

# Public sign-up is disabled.
PAPERCLIP_AUTH_DISABLE_SIGN_UP=true

# Approved users can still create their own company after you
# create their account manually.
PAPERCLIP_ANY_USER_CAN_CREATE_COMPANY=true

# Required in authenticated mode
BETTER_AUTH_SECRET=replace_with_long_random_secret
PAPERCLIP_AGENT_JWT_SECRET=replace_with_long_random_secret

# Provider keys
OPENAI_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me
